# Argumet $1 should be the ordering of the preferred broadcast station - Should be "1" for default station.
STATION=$(ip addr | grep BROADCAST | sed -n "$1p" | awk '{print $2}')

LOCAL=$(ip addr show dev ${STATION//:} | grep inet | grep -v 'inet6' | awk '{print $2}' | cut -d'/' -f1)

export API_ENDPOINT="https://$LOCAL:3000"
