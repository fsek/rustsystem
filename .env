STATION=$(ip addr | grep BROADCAST | head -n 1 | awk '{print $2}')

local=$(ip addr show dev ${STATION//:} | grep inet | grep -v 'inet6' | awk '{print $2}' | cut -d'/' -f1)

export DEV=true

export API_ENDPOINT_SERVER="http://localhost:1443"
export API_ENDPOINT_TRUSTAUTH_TO_SERVER="https://localhost:1444"
export API_ENDPOINT_TRUSTAUTH="http://localhost:2443"
export API_ENDPOINT_SERVER_TO_TRUSTAUTH="https://localhost:2444"

export SALT_HEX="66efafd01e57e93bf7a970ac51fe7660"
export KEYGEN_ITERATIONS=200000
